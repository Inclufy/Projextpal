# ProjeXtPal backend environment — copy to backend/.env and fill in real values.
# NEVER commit the real .env (it is gitignored). These are required at startup.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres (POSTGRES_PASSWORD is required — settings.py has no default)
POSTGRES_DB=projextpal
POSTGRES_USER=projextpal
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Used by the root import_content.py helper script
DB_PASSWORD=

# Third-party (set as needed)
SENTRY_DSN=
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
OPENAI_API_KEY=
